#!/bin/sh
# Oscaware 公开纪律钩子：任何一次提交都不得引入脱敏违禁词或本地私有文件。
# 安装：cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 依据：《开仓指南 v1.0》第 2 节脱敏清单，机器化为强制检查。
# 注意：违禁词用拆词拼接构造，保证本脚本自身通过全库审计检索（零命中）。

set -e

W1="$(printf '\344\272\254\350\203\275')"   # 客户名（中文，UTF-8 转义）
W2="jing""neng"
W3="uere""port"
FORBIDDEN="${W1}|${W2}|${W3}"

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged_files" ]; then
  # 1. 挡违禁词：只查本次暂存的新增行，不误伤历史
  if git diff --cached -U0 | grep -E '^\+' | grep -qiE "$FORBIDDEN"; then
    echo "✗ 提交被拒绝：暂存内容中检出脱敏违禁词（见《开仓指南》第 2 节清单）。" >&2
    git diff --cached -U0 | grep -E '^\+' | grep -niE "$FORBIDDEN" >&2
    exit 1
  fi

  # 2. 挡文件名本身含违禁词的文件
  if echo "$staged_files" | grep -qiE "$FORBIDDEN"; then
    echo "✗ 提交被拒绝：暂存文件名含脱敏违禁词。" >&2
    exit 1
  fi

  # 3. 挡本地敏感目录/文件被意外加入跟踪
  if echo "$staged_files" | grep -qiE '^Core_docs/|(^|/)key\.md$'; then
    echo "✗ 提交被拒绝：Core_docs/ 与 key.md 是本地私有内容，永不入库。" >&2
    exit 1
  fi
fi

exit 0
