#!/bin/sh
# Oscaware 公开纪律钩子：任何一次提交都不得引入脱敏违禁词或本地私有文件。
# 安装：cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 依据：《开仓指南 v1.0》第 2 节脱敏清单，机器化为强制检查。
# 注意：违禁词表不入库——公开脚本只携带机制，词表读取本地未跟踪文件
#       Core_docs/redlist.txt（每行一个 grep -E 模式；# 开头与空行忽略）。
#       词表缺失时跳过词检（第三方克隆无此文件属正常）；路径拦截始终生效。

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
REDLIST="$REPO_ROOT/Core_docs/redlist.txt"
FORBIDDEN=""
if [ -f "$REDLIST" ]; then
  FORBIDDEN="$(grep -vE '^[[:space:]]*(#|$)' "$REDLIST" | paste -s -d'|' -)"
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged_files" ]; then
  if [ -n "$FORBIDDEN" ]; then
    # 1. 挡违禁词：只查本次暂存的新增行，不误伤历史
    if git diff --cached -U0 | grep -E '^\+' | grep -qiE "$FORBIDDEN"; then
      echo "✗ 提交被拒绝：暂存内容中检出脱敏违禁词（词表：Core_docs/redlist.txt）。" >&2
      git diff --cached -U0 | grep -E '^\+' | grep -niE "$FORBIDDEN" >&2
      exit 1
    fi

    # 2. 挡文件名本身含违禁词的文件
    if echo "$staged_files" | grep -qiE "$FORBIDDEN"; then
      echo "✗ 提交被拒绝：暂存文件名含脱敏违禁词。" >&2
      exit 1
    fi
  fi

  # 3. 挡本地敏感目录/文件被意外加入跟踪
  if echo "$staged_files" | grep -qiE '^Core_docs/|(^|/)key\.md$|(^|/)redlist\.txt$'; then
    echo "✗ 提交被拒绝：Core_docs/、key.md 与 redlist.txt 是本地私有内容，永不入库。" >&2
    exit 1
  fi
fi

exit 0
